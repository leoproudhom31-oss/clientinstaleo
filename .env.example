# ------------------------------------------------------------------
#  Configuration optionnelle de l'app de bureau InstaLeo.
#  Copie ce fichier en ".env" a la racine si tu veux personnaliser.
#  Tout est optionnel : l'app fonctionne sans .env.
# ------------------------------------------------------------------

# Secret utilise pour chiffrer la session Instagram stockee localement.
# Optionnel (une valeur par defaut est utilisee). Pour plus de securite :
#   openssl rand -hex 32
SESSION_SECRET=

# (Optionnel) Proxy pour le trafic Instagram, si ton reseau est surveille
# ou si tu veux forcer une IP precise. Formats acceptes :
#   http://utilisateur:motdepasse@hote:port
#   socks5://utilisateur:motdepasse@hote:port
# En temps normal, laisse vide : les requetes partent deja de ton IP.
IG_PROXY=
