# ------------------------------------------------------------------
#  Variables d'environnement — a configurer dans Vercel (Settings > Environment Variables)
#  ou en local dans un fichier .env (jamais committe).
# ------------------------------------------------------------------

# Secret utilise pour chiffrer la session Instagram stockee dans un cookie httpOnly.
# Genere une valeur aleatoire longue, par ex. :  openssl rand -hex 32
SESSION_SECRET=change-moi-avec-une-chaine-aleatoire-de-64-caracteres

# (Optionnel) Autorise le mode connexion reelle a l'API privee Instagram.
# Mets "false" pour forcer uniquement le mode demo (aucun appel a Instagram).
# Par defaut : true
ENABLE_LIVE_LOGIN=true
