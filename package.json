{
  "name": "clientinstaleo",
  "private": true,
  "version": "1.0.0",
  "description": "Client Instagram alternatif, sans trackers, avec une interface facon Discord. Fonctionne en client local (ton IP) ou en demo sur Vercel.",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "serve": "node server.cjs",
    "start": "npm run build && node server.cjs",
    "desktop": "electron electron/main.cjs",
    "desktop:build": "npm run build && electron-builder",
    "typecheck": "tsc --noEmit"
  },
  "build": {
    "appId": "com.instaleo.app",
    "productName": "InstaLeo",
    "files": [
      "dist/**",
      "api/**",
      "server/**",
      "server.cjs",
      "electron/**",
      "package.json"
    ],
    "directories": {
      "output": "release"
    }
  },
  "dependencies": {
    "instagram-private-api": "^1.46.1",
    "lucide-react": "^0.408.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "typescript": "^5.5.4",
    "vite": "^5.4.2"
  }
}
